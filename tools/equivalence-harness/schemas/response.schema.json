{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ghoul.local/kms/response.schema.json",
  "title": "KMS Oracle Response",
  "type": "object",
  "required": ["ok", "output", "output_bytes_hex", "error", "meta"],
  "properties": {
    "ok": { "type": "boolean" },
    "output": {},
    "output_bytes_hex": { "type": "string" },
    "error": { "type": ["string", "null"] },
    "meta": {
      "type": "object",
      "required": ["rng_draws", "impl_version"],
      "properties": {
        "rng_draws": { "type": "integer", "minimum": 0 },
        "impl_version": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
