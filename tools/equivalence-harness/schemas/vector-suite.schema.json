{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ghoul.local/kms/vector-suite.schema.json",
  "title": "Equivalence Vector Suite",
  "type": "object",
  "required": ["name", "cases"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "op", "inputs"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "op": { "type": "string", "minLength": 1 },
          "inputs": { "type": "object" },
          "rng": {
            "type": "object",
            "required": ["mode", "seed_hex", "stream"],
            "properties": {
              "mode": { "type": "string", "enum": ["deterministic"] },
              "seed_hex": { "type": "string", "pattern": "^(0x)?[0-9a-fA-F]{64}$" },
              "stream": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
